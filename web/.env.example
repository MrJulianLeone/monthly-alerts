# Neon Postgres
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# OpenAI (GPT-4o-mini for coaching, GPT-4o for meal vision)
OPENAI_API_KEY=

# Resend (emails: parent setup, monthly summaries, billing prompts)
RESEND_API_KEY=
RESEND_FROM_EMAIL=coach@monthlyalerts.com
RESEND_FROM_NAME=MonthlyAlerts

# Stripe (monthly subscriptions, first 30 days free)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://monthlyalerts.com
AUTH_SECRET=

# Protects POST /api/admin/migrate
MIGRATE_SECRET=
