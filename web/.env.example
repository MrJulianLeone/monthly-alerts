# Neon Postgres
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# OpenAI (GPT-4o-mini for coaching, GPT-4o for meal vision)
OPENAI_API_KEY=

# Resend (emails: parent setup, monthly summaries, billing prompts, referrals)
RESEND_API_KEY=
# Must be on the Resend-verified sending domain (alerts.monthlyalerts.com)
RESEND_FROM_EMAIL=coach@alerts.monthlyalerts.com
RESEND_FROM_NAME=MonthlyAlerts

# Stripe (monthly subscriptions, first 30 days free)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=            # recurring monthly price id (price_...)

# Note: meal photos are analyzed inline by the vision model and never stored,
# so no blob/object storage token is required.

# Mobile OAuth (Sign in with Apple / Google)
APPLE_BUNDLE_ID=            # e.g. com.monthlyalerts.app
GOOGLE_CLIENT_IDS=          # comma-separated allowed OAuth client ids

# App
NEXT_PUBLIC_APP_URL=https://monthlyalerts.com
# Note: the sole admin account is hardcoded in web/lib/admin.ts — no env var.

# Protects cron endpoints (Vercel sends Authorization: Bearer CRON_SECRET)
CRON_SECRET=

# Protects POST /api/admin/migrate
MIGRATE_SECRET=
